{
    "name": "greeting-card/api",
    "description": "Greeting Card AI - Backend API with Symfony and API Platform",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "symfony/console": "^6.4",
        "symfony/dotenv": "^6.4",
        "symfony/flex": "^2.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/routing": "^6.4",
        "symfony/runtime": "^6.4",
        "symfony/yaml": "^6.4",
        "api-platform/core": "^3.2",
        "doctrine/annotations": "^20.0",
        "doctrine/doctrine-bundle": "^2.10",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "doctrine/orm": "^2.16",
        "nelmio/cors-bundle": "^2.4",
        "symfony/serializer": "^6.4",
        "symfony/validator": "^6.4",
        "symfony/twig-bundle": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "symfony/maker-bundle": "^1.51"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
